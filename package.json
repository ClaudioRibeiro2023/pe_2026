{
  "name": "pe-2026",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": {
    "name": "PE 2026",
    "email": "contato@pe2026.com.br"
  },
  "description": "Sistema de Planejamento Estratégico 2026",
  "scripts": {
    "dev": "vite --force",
    "dev:electron": "cross-env ELECTRON=true vite --force",
    "build": "tsc -b && vite build",
    "build:electron": "cross-env ELECTRON=true tsc -b && cross-env ELECTRON=true vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "cross-env E2E_TEST_EMAIL=admin@pe2026.local E2E_TEST_PASSWORD=pe2026@admin playwright test --config=playwright.local.config.ts",
    "analyze": "cross-env ANALYZE=true vite build",
    "electron:start": "electron .",
    "electron:build": "npm run build:electron && electron-builder --win",
    "electron:build:dir": "npm run build:electron && electron-builder --win --dir"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
    "@sentry/react": "^10.34.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "chart.js": "^4.4.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.30.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-router-dom": "^6.21.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4"
  },
  "overrides": {
    "esbuild": "0.25.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.17",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.4.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.17"
  },
  "optionalDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-updater": "^6.7.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
